# Website server (copy to website/.env and fill in)

PORT=3000

# Supabase — Project Settings → API
# When both are set, waitlist signups save to Supabase.
# IMPORTANT: SERVICE_ROLE_KEY must stay on the server only (never in browser JS).
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# Set in production so the server refuses to run without Supabase configured.
NODE_ENV=production

# Cloudflare Turnstile — dash.cloudflare.com → Turnstile → Add site
# Test secret (always passes): 1x0000000000000000000000000000000AA
# TURNSTILE_SECRET_KEY="YOUR_TURNSTILE_SECRET_KEY"
TURNSTILE_SECRET_KEY="Your_Turnstile_Secret_Key_Here"

# Resend — resend.com → API Keys
RESEND_API_KEY="YOUR_RESEND_API_KEY"

# Base URL used in verification email links (no trailing slash)
# Local: http://localhost:3000  |  Production: https://www.kleoklaw.com
APP_URL="http://localhost:3000"

# Optional: allow local SQLite fallback (dev only). Leave blank for Supabase.
# WAITLIST_STORAGE=sqlite
