# Website server (copy to website/.env and fill in)

PORT=3000

# Supabase — Project Settings → API
# When both are set, waitlist signups save to Supabase.
# IMPORTANT: SERVICE_ROLE_KEY must stay on the server only (never in browser JS).
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# Set in production so the server refuses to run without Supabase configured.
NODE_ENV=production

# Optional: allow local SQLite fallback (dev only). Leave blank for Supabase.
# WAITLIST_STORAGE=sqlite
