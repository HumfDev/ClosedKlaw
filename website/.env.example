# Website server (copy to website/.env and fill in)

PORT=3000

# Supabase — Project Settings → API
# When URL + service role are set, waitlist signups save to Supabase.
# ANON_KEY is public (browser) — used for Google sign-in on the waitlist page.
# SERVICE_ROLE_KEY must stay on the server only (never in browser JS).
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# Vercel / production: set the same three vars in Project → Settings → Environment Variables, then redeploy.
#
# Google Cloud (Web OAuth client):
#   Authorized JavaScript origins: https://kleoklaw.com, http://localhost:3000
#   Authorized redirect URI: https://<project-ref>.supabase.co/auth/v1/callback
#
# Supabase → Authentication → URL configuration:
#   Site URL: kleoklaw.com (or https://kleoklaw.com)
#   Redirect URLs: https://kleoklaw.com/

# Set in production so the server refuses to run without Supabase configured.
NODE_ENV=production

# Cloudflare Turnstile — dash.cloudflare.com → Turnstile → Add site
# Test secret (always passes): 1x0000000000000000000000000000000AA
# TURNSTILE_SECRET_KEY="YOUR_TURNSTILE_SECRET_KEY"
TURNSTILE_SECRET_KEY="Your_Turnstile_Secret_Key_Here"

# Resend — resend.com → API Keys
RESEND_API_KEY="YOUR_RESEND_API_KEY"

# Base URL used in verification email links (no trailing slash)
# Local: http://localhost:3000  |  Production: https://www.kleoklaw.com
APP_URL="http://localhost:3000"

# Onboarding app (static pages on Vercel — verify.html, resume.html, billing.html)
# Production: https://app.kleoklaw.com
KLEOKLAW_APP_URL="http://localhost:3000"
KLEOKLAW_API_URL="https://api.kleoklaw.com"

# Stripe (used by Cloud Run API, not the static Vercel site)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_SUCCESS_URL=https://app.kleoklaw.com/?step=billing-done

# Click-to-text on landing page — E.164 SendBlue line (same as KleoKlaw SENDBLUE_FROM_NUMBER)
KLEO_PHONE="+14356917120"
# SENDBLUE_FROM_NUMBER="+14356917120"

# Optional: allow local SQLite fallback (dev only). Leave blank for Supabase.
# WAITLIST_STORAGE=sqlite
