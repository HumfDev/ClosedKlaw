# Website server (copy to website/.env and fill in)

PORT=3000

# Supabase — Project Settings → API
# When URL + service role are set, waitlist signups save to Supabase.
# ANON_KEY is public (browser) — used for Google sign-in on the waitlist page.
# SERVICE_ROLE_KEY must stay on the server only (never in browser JS).
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# Vercel / production: set the same three vars in Project → Settings → Environment Variables, then redeploy.
#
# Google Cloud (Web OAuth client):
#   Authorized JavaScript origins: https://kleoklaw.com, http://localhost:3000
#   Authorized redirect URI: https://<project-ref>.supabase.co/auth/v1/callback
#
# Supabase → Authentication → URL configuration:
#   Site URL: kleoklaw.com (or https://kleoklaw.com)
#   Redirect URLs: https://kleoklaw.com/, http://localhost:3000/

# Set in production so the server refuses to run without Supabase configured.
NODE_ENV=production

# Optional: allow local SQLite fallback (dev only). Leave blank for Supabase.
# WAITLIST_STORAGE=sqlite
